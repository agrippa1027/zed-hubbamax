          "string.escape": { "color": "#d787d7" },
          "string.regex": { "color": "#d787d7" },
          "string.special": { "color": "#d787d7" },
          "string.special.symbol": { "color": "#d75f87" },
          "tag": { "color": "#5f87af" },
          "text.literal": { "color": "#5faf5f" },
          "title": { "color": "#d7af87", "font_weight": 700 },
          "type": { "color": "#5f87af" },
          "variable": { "color": "#bcbcbc" },
